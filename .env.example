# Gemini API 키 (릴리스 노트 요약용, https://aistudio.google.com/apikey 에서 무료 발급).
# 없으면 요약 대신 원문 발췌를 보냅니다.
GEMINI_API_KEY=

# 기본 Slack Incoming Webhook URL (모든 소스의 폴백)
SLACK_WEBHOOK_URL=

# (선택) 채널별 웹훅 — sources/*.yml의 channel 키와 매핑됩니다.
# 예: channel: ai-news → SLACK_WEBHOOK_AI_NEWS
# SLACK_WEBHOOK_AI_NEWS=

# (선택) 요약에 사용할 모델 변경
# SUMMARY_MODEL=gemini-flash-latest

# 로컬 테스트용: Slack에 보내지 않고 콘솔에 출력
# DRY_RUN=1
